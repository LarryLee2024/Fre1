{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 100,
    "showLineNumbers": true,
    "truncateBase64": false,
    "copyToClipboard": false,
    "includeFullDirectoryStructure": false,
    "tokenCountTree": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 50
    }
  },
  "include": [
    ".qoder/",
    ".trae/",
    "docs/",
    "**/mod.rs",
    "**/plugin.rs",
    "**/integration/**/*.rs",
    "**/integration/**/*.rs",
    "AGENTS.md",
    "Cargo.toml",
    "CLAUDE.md",
    "README.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".claude",
      ".codegraph",
      ".idea",
      ".vscode/**",
      ".mimocode",
      ".omo",
      "target/**",
      ".git/**",
      ".gitignore",
      ".qoderignore",
      "**/*.ignore",
      "---------------代码--------------",
      "**/*.lock",
      "**/ai_ignore_this_dir/**",
      "---------------资产-------------",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.aseprite",
      "**/*.blend",
      "**/*.wav",
      "**/*.ogg"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}