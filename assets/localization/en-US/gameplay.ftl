### Gameplay text — en-US
### Prefix: gameplay (combat log, status messages, notifications)

-gameplay-combat-damage = {$source} deals {$damage} damage to {$target}
-gameplay-combat-heal = {$source} restores {$value} HP to {$target}
-gameplay-combat-miss = {$source} attack misses {$target}
-gameplay-combat-critical = Critical hit! {$damage} damage!
-gameplay-combat-immunity = {$target} is immune to {$effect}
-gameplay-combat-resist = {$target} resists {$effect}
-gameplay-combat-dodge = {$target} dodges the attack
-gameplay-combat-counter = {$source} counters for {$damage} damage

-gameplay-buff-applied = {$effect} applied to {$target}
-gameplay-buff-expired = {$effect} expired on {$target}
-gameplay-buff-tick = {$effect} deals {$damage} damage to {$target}

-gameplay-level-up = {$entity} reached level {$level}!
-gameplay-skill-unlocked = {$entity} learned {$skill}
-gameplay-quest-updated = Quest updated: {$quest}
-gameplay-quest-completed = Quest completed: {$quest}
-gameplay-quest-failed = Quest failed: {$quest}
